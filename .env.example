OPENAI_API_KEY=<your-model-api-key>
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
KNOWLEDGE_BASE_URL=
ENABLE_SYNC_WEB_SUPPLEMENT=false
API_KEYS=
API_KEY_REGISTRY_PATH=
REDIS_URL=redis://127.0.0.1:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30

# Account, invite-only registration, email verification, session, and daily quota
APP_DB_PATH=data/app/application.sqlite
DOMAIN_LEXICON_RUNTIME_PATH=data/app/domain_lexicon_runtime.json
AUTH_REQUIRED=true
REGISTRATION_ENABLED=true
SESSION_COOKIE_NAME=kb_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=168
DAILY_QUOTA_DEFAULT=10
QUOTA_TIMEZONE=Asia/Shanghai
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_SECRET=<long-random-secret>
EMAIL_CODE_TTL_MINUTES=10
EMAIL_CODE_COOLDOWN_SECONDS=60
EMAIL_CODE_DAILY_LIMIT=5
EMAIL_DEBUG=false
EMAIL_PROVIDER=agentmail
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=geowiki@agentmail.to
AGENTMAIL_BASE_URL=https://api.agentmail.to/v0
AGENTMAIL_PROXY_URL=
PUBLIC_BASE_URL=

# Aliyun Bailian / DashScope embedding
DASHSCOPE_API_KEY=
EMBEDDING_PROVIDER=aliyun
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10

# Controlled Agentic RAG v1.0
QUERY_PLANNER_ENABLED=true
EVIDENCE_RERANKER_ENABLED=true
QUESTION_RESOLUTION_ENABLED=true
QUESTION_RESOLUTION_MAX_TOKENS=500
QUESTION_RESOLUTION_MIN_CONFIDENCE=0.55
QUERY_PLANNER_MAX_TOKENS=600
EVIDENCE_RERANKER_MAX_TOKENS=800
ANSWER_MAX_TOKENS=1000
STRUCTURED_TEMPERATURE=0
ANSWER_TEMPERATURE=0.2
MAX_RETRIEVAL_ROUNDS=2
CONTROLLED_MULTI_QUERY_ENABLED=true
CONTROLLED_MULTI_QUERY_MAX=2
MMR_ENABLED=true
MMR_LAMBDA=0.7
MMR_DUPLICATE_TRIGGER=0.8
ANN_SEARCH_ENABLED=true
ANN_EXPANSION_SEARCH=64
VECTOR_FALLBACK_SCAN_LIMIT=100
ANN_INDEX_PATH=data/knowledge_base/indexes/dense.usearch
ANN_MANIFEST_PATH=data/knowledge_base/indexes/dense_manifest.json
RETRIEVAL_TRACE_ENABLED=true
RETRIEVAL_TRACE_PATH=data/app/retrieval_traces.jsonl
